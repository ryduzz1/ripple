          </CEFCommandLine>
        </Resources>
        <Lifecycle>
          <AutoVisible>true</AutoVisible>
        </Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>Ripple</Menu>
          <Geometry>
            <Size>
              <Height>760</Height>
              <Width>520</Width>
            </Size>
            <MinSize>
              <Height>520</Height>
              <Width>420</Width>
            </MinSize>
          </Geometry>
