<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest Version="7.0"
  ExtensionBundleId="com.ryder.ripple"
  ExtensionBundleVersion="0.1.0"
  ExtensionBundleName="Ripple"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
